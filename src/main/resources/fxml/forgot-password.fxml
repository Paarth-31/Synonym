<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane" style="-fx-background-color: #090a0c;" stylesheets="@../styles/auth-theme.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.ForgotPasswordController">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-control-inner-background: transparent; -fx-border-width: 0;">
            <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="40" right="20" bottom="40" left="20"/>
                </padding>

                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 40 0;">
                    <Label text="SYNONYM" styleClass="title-logo"/>
                    <Label text="Account Recovery" styleClass="subtitle-text"/>
                </VBox>

                <VBox styleClass="form-container" spacing="5">

                    <Label text="Reset Password" styleClass="header-text" style="-fx-padding: 0 0 5 0;"/>
                    <Label text="Enter your email to receive a reset link." styleClass="subtitle-text" style="-fx-padding: 0 0 20 0;"/>

                    <VBox styleClass="form-field-box">
                        <Label text="Email Address" styleClass="form-label"/>
                        <TextField fx:id="emailField" promptText="Enter your registered email" styleClass="text-field"/>
                    </VBox>

                    <VBox fx:id="newPasswordBox" styleClass="form-field-box">
                        <Label text="New Password" styleClass="form-label"/>
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="text-field"/>
                    </VBox>

                    <VBox fx:id="confirmPasswordBox" styleClass="form-field-box">
                        <Label text="Confirm Password" styleClass="form-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="text-field"/>
                    </VBox>

                    <Label fx:id="errorLabel" text="" styleClass="error-label"/>

                    <VBox spacing="12" style="-fx-padding: 15 0 0 0;">
                        <Button fx:id="resetButton" text="RESET PASSWORD" prefHeight="45" maxWidth="Infinity" styleClass="primary-button" onAction="#handleResetPassword"/>
                        <Button fx:id="backButton" text="Back to Login" prefHeight="45" maxWidth="Infinity" styleClass="secondary-button" onAction="#goToLogin"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>