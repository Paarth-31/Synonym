<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.ForgotPasswordController" styleClass="root-pane">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #0a0a0a;">
            <padding>
                <Insets top="80" right="40" bottom="80" left="40"/>
            </padding>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Reset Password" style="-fx-font-size: 40px; -fx-font-weight: 900; -fx-text-fill: #ffffff;"/>
                <Label text="Enter your email to reset your password" style="-fx-font-size: 13px; -fx-text-fill: #b0b0b0;"/>
            </VBox>

            <!-- Form Container -->
            <VBox spacing="18" style="-fx-max-width: 400px; -fx-padding: 40; -fx-background-color: #1a1a1a; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 10;">

                <!-- Email Field -->
                <VBox spacing="8">
                    <Label text="Email Address" style="-fx-text-fill: #c0c0c0; -fx-font-weight: 600;"/>
                    <TextField fx:id="emailField" promptText="Enter your email"
                               style="-fx-padding: 12; -fx-font-size: 13px; -fx-control-inner-background: #0a0a0a; -fx-text-fill: #ffffff;"/>
                </VBox>

                <!-- New Password -->
                <VBox spacing="8">
                    <Label text="New Password" style="-fx-text-fill: #c0c0c0; -fx-font-weight: 600;"/>
                    <PasswordField fx:id="newPasswordField" promptText="Enter new password"
                                   style="-fx-padding: 12; -fx-font-size: 13px; -fx-control-inner-background: #0a0a0a; -fx-text-fill: #ffffff;"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="8">
                    <Label text="Confirm Password" style="-fx-text-fill: #c0c0c0; -fx-font-weight: 600;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"
                                   style="-fx-padding: 12; -fx-font-size: 13px; -fx-control-inner-background: #0a0a0a; -fx-text-fill: #ffffff;"/>
                </VBox>

                <!-- Error Label -->
                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e81123; -fx-font-size: 11px; -fx-font-weight: 600;"/>

                <!-- Reset Button -->
                <Button fx:id="resetButton" text="RESET PASSWORD" prefHeight="45"
                        style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 12; -fx-background-color: #9c27b0; -fx-text-fill: #ffffff; -fx-cursor: hand; -fx-background-radius: 6;"/>

                <!-- Back Button -->
                <Button fx:id="backButton" text="Back to Login" prefHeight="40"
                        style="-fx-background-color: transparent; -fx-text-fill: #9c27b0; -fx-font-weight: 600; -fx-cursor: hand; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 6; -fx-font-size: 12px;"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>
