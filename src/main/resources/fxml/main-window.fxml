<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../styles/dark-professional-theme.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.MainWindowController"
            prefWidth="1280" prefHeight="800">

    <top>
        <VBox styleClass="top-section">

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15 20;">
                <Label text="SYNONYM" styleClass="app-title"/>
                <Label text="Intelligent File Discovery" styleClass="app-subtitle"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="homeButton" text="Home" styleClass="nav-btn" onAction="#handleHomeButton"/>
                <Button fx:id="profileButton" text="Profile" styleClass="nav-btn" onAction="#handleProfileButton"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 20 15 20;">
                <Button text="&lt;" styleClass="icon-btn"/>
                <Button text="&gt;" styleClass="icon-btn"/>
                <Button text="^" styleClass="icon-btn"/>

                <TextField fx:id="pathField" text="C:\Users\HP" HBox.hgrow="ALWAYS" styleClass="path-field"/>

                <Button text="Refresh" styleClass="icon-btn"/>
                <Button text="..." styleClass="icon-btn"/>

                <Button fx:id="addFilesBtn" text="+ Add Files" styleClass="primary-btn" onAction="#handleAddFiles"/>
                <Button fx:id="analyzeBtn" text="Analyze" styleClass="primary-btn" onAction="#handleAnalyze"/>
            </HBox>

            <HBox style="-fx-padding: 0 20 15 20;">
                <TextField fx:id="searchField" promptText="Search files, genres, or content..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
            </HBox>

        </VBox>
    </top>

    <left>
        <VBox spacing="20" styleClass="sidebar" prefWidth="240">

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="QUICK ACCESS" styleClass="section-header"/>
                <TreeView fx:id="directoryTree" VBox.vgrow="ALWAYS" styleClass="tree-view"/>
            </VBox>

            <Button fx:id="selectedFilesBtn" text="Selected Files" maxWidth="Infinity" styleClass="primary-btn"/>

            <VBox spacing="5">
                <Label text="BOOKMARKS" styleClass="section-header"/>
            </VBox>

            <VBox spacing="10">
                <Label text="AI FEATURES" styleClass="section-header"/>
                <Button fx:id="discoveryBtn" text="Discovery Mode" maxWidth="Infinity" styleClass="ai-feature-btn" onAction="#handleDiscoveryMode"/>
                <Button fx:id="visualizerBtn" text="3D Visualizer" maxWidth="Infinity" styleClass="ai-feature-btn" onAction="#handleVisualizer"/>
            </VBox>

        </VBox>
    </left>

    <center>
        <TableView fx:id="fileTable" styleClass="file-table">
            <columns>
                <TableColumn text="Name" prefWidth="300" fx:id="nameCol"/>
                <TableColumn text="Genre" prefWidth="150" fx:id="genreCol"/>
                <TableColumn text="Date Modified" prefWidth="200" fx:id="dateCol"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

    <right>
        <VBox spacing="20" styleClass="right-panel" prefWidth="280">

            <VBox styleClass="info-card" spacing="15">
                <Label text="File Statistics" styleClass="card-title"/>
                <HBox>
                    <Label text="Total Files:" style="-fx-text-fill: #94a3b8;" prefWidth="100"/>
                    <Label fx:id="totalFilesLabel" text="0" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold;"/>
                </HBox>
                <HBox>
                    <Label text="Genres Found:" style="-fx-text-fill: #94a3b8;" prefWidth="100"/>
                    <Label fx:id="totalGenresLabel" text="0" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <VBox styleClass="info-card" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="Detected Genres" styleClass="card-title"/>

                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="genreListContainer" spacing="12">
                    </VBox>
                </ScrollPane>
            </VBox>

        </VBox>
    </right>

    <bottom>
        <HBox styleClass="status-bar" spacing="20" alignment="CENTER_LEFT">
            <Label text="System Ready" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Synonym v2.0" styleClass="status-text"/>
        </HBox>
    </bottom>

</BorderPane>