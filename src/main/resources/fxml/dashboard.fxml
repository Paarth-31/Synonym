
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainBorderPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.DashboardController"
            style="-fx-background-color: #0a0a0a;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #1a1a1a; -fx-padding: 16 20; -fx-border-color: #3a3a3a; -fx-border-width: 0 0 1 0;">
            <Label text="SYNONYM" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #ffffff;"/>
            <Label text="Dashboard" style="-fx-font-size: 14px; -fx-text-fill: #9c27b0; -fx-font-weight: 600;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome!" style="-fx-font-size: 13px; -fx-text-fill: #c0c0c0;"/>
            <Button fx:id="profileButton" text="👤 Profile" style="-fx-background-color: #9c27b0; -fx-text-fill: #ffffff; -fx-padding: 8 14; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="logoutButton" text="Logout" style="-fx-background-color: transparent; -fx-text-fill: #c0c0c0; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="1" style="-fx-background-color: #0a0a0a;">
            <VBox style="-fx-background-color: #1a1a1a; -fx-border-color: #3a3a3a; -fx-border-width: 0 1 0 0;" prefWidth="320" spacing="0">
                <padding>
                    <Insets top="20" right="15" bottom="20" left="15"/>
                </padding>

                <VBox spacing="10" style="-fx-padding: 0 0 20 0;">
                    <Label text="📋 Chat History" style="-fx-font-size: 15px; -fx-text-fill: #ffffff; -fx-font-weight: 700;"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Total Sessions:" style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
                        <Label fx:id="chatCountLabel" text="0" style="-fx-text-fill: #9c27b0; -fx-font-weight: 700; -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>

                <ListView fx:id="chatHistoryList" style="-fx-control-inner-background: #0a0a0a; -fx-font-size: 12px; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 6; -fx-padding: 8;" VBox.vgrow="ALWAYS"/>

                <Region VBox.vgrow="ALWAYS" minHeight="20"/>

                <Button fx:id="getStartedButton" text="➕ NEW ANALYSIS" prefHeight="46"
                        style="-fx-background-color: #9c27b0; -fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-font-size: 13px; -fx-padding: 12 0; -fx-cursor: hand;" maxWidth="Infinity"/>
            </VBox>

            <VBox style="-fx-background-color: #0a0a0a;" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <VBox spacing="20" style="-fx-padding: 0 0 30 0;">
                    <Label text="Welcome to Your Dashboard" style="-fx-font-size: 24px; -fx-text-fill: #ffffff; -fx-font-weight: 900;"/>
                    <Label text="Manage your file analysis sessions and continue where you left off" style="-fx-font-size: 13px; -fx-text-fill: #b0b0b0; -fx-wrap-text: true;"/>
                </VBox>

                <HBox spacing="15" style="-fx-padding: 0 0 20 0;">
                    <VBox style="-fx-background-color: #1a1a1a; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 16; -fx-min-width: 150;" alignment="CENTER" spacing="10">
                        <Label text="📊" style="-fx-font-size: 32px;"/>
                        <Label text="Files Analyzed" style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
                        <Label text="0" style="-fx-text-fill: #9c27b0; -fx-font-size: 18px; -fx-font-weight: 700;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #1a1a1a; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 16; -fx-min-width: 150;" alignment="CENTER" spacing="10">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="Total Sessions" style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
                        <Label fx:id="sessionCountLabel" text="0" style="-fx-text-fill: #9c27b0; -fx-font-size: 18px; -fx-font-weight: 700;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #1a1a1a; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 16; -fx-min-width: 150;" alignment="CENTER" spacing="10">
                        <Label text="⏱️" style="-fx-font-size: 32px;"/>
                        <Label text="Last Active" style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
                        <Label text="Today" style="-fx-text-fill: #9c27b0; -fx-font-size: 18px; -fx-font-weight: 700;"/>
                    </VBox>
                </HBox>

                <VBox spacing="12" style="-fx-padding: 20 0 0 0; -fx-border-color: #3a3a3a; -fx-border-width: 1 0 0 0;">
                    <Label text="Session Details" style="-fx-font-size: 14px; -fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-padding: 16 0 0 0;"/>
                    <TextArea fx:id="chatDetailsArea" style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: #c0c0c0; -fx-font-size: 12px; -fx-border-color: #3a3a3a; -fx-border-width: 1; -fx-border-radius: 6; -fx-padding: 12;" wrapText="true" prefRowCount="8" VBox.vgrow="ALWAYS" editable="false">
                        <text>Select a chat from the list to view details, or click 'New Analysis' to start a new session.</text>
                    </TextArea>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>