<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainBorderPane" styleClass="root-pane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.LoginController">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-control-inner-background: transparent;">
            <VBox alignment="CENTER" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #0a0a0a, #1a1a1a); -fx-padding: 60 20;" VBox.vgrow="ALWAYS">

                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 0 0 40 0;">
                    <Label text="SYNONYM" styleClass="title-logo"/>
                    <Label text="Intelligent File Discovery Platform" styleClass="subtitle-text"/>
                </VBox>

                <VBox styleClass="form-container">

                    <Label text="Welcome Back" style="-fx-font-size: 18px; -fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-padding: 0 0 28 0;"/>

                    <VBox styleClass="form-field-box">
                        <Label text="Username" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field"/>
                    </VBox>

                    <VBox styleClass="form-field-box">
                        <Label text="Password" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field"/>
                    </VBox>

                    <CheckBox fx:id="rememberMe" text="Remember me" style="-fx-text-fill: #c0c0c0; -fx-font-size: 12px; -fx-padding: 0 0 8 0;"/>

                    <Label fx:id="errorLabel" text="" styleClass="error-label" style="-fx-padding: 8 0;"/>

                    <ProgressBar fx:id="loadingBar" visible="false" prefHeight="4" style="-fx-padding: 8 0; -fx-accent: #9c27b0;"/>

                    <Button fx:id="loginButton" text="LOGIN" prefHeight="48" maxWidth="Infinity"
                            styleClass="primary-button" style="-fx-padding: 14 24; -fx-font-size: 14px;"/>

                    <Button fx:id="forgotPasswordButton" text="Forgot Password?" prefHeight="30"
                            styleClass="text-button" maxWidth="Infinity" alignment="CENTER"/>

                    <Separator style="-fx-padding: 16 0;"/>

                    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 0 0;">
                        <Label text="Don't have an account?" style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
                        <Button fx:id="signupButton" text="Sign up" styleClass="text-button"/>
                    </HBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>