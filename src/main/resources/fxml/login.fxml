<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainBorderPane" styleClass="root-pane" style="-fx-background-color: #090a0c;" stylesheets="@../styles/auth-theme.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.LoginController">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: #090a0c; -fx-background-color: #090a0c; -fx-control-inner-background: #090a0c; -fx-border-width: 0;">
            <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS" style="-fx-background-color: #090a0c;">
                <padding>
                    <Insets top="40" right="20" bottom="40" left="20"/>
                </padding>

                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 40 0;">
                    <Label text="SYNONYM" styleClass="title-logo"/>
                    <Label text="Intelligent File Discovery Platform" styleClass="subtitle-text"/>
                </VBox>

                <VBox styleClass="form-container" spacing="5">

                    <Label text="Welcome Back" styleClass="header-text" style="-fx-padding: 0 0 20 0;"/>

                    <VBox styleClass="form-field-box">
                        <Label text="Username" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field"/>
                    </VBox>

                    <VBox styleClass="form-field-box">
                        <Label text="Password" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
                        <CheckBox fx:id="rememberMe" text="Remember me" styleClass="check-box"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="forgotPasswordButton" text="Forgot Password?" styleClass="text-button" onAction="#goToForgotPassword"/>
                    </HBox>

                    <Label fx:id="errorLabel" text="" styleClass="error-label"/>

                    <ProgressBar fx:id="loadingBar" visible="false" prefHeight="4" maxWidth="Infinity" style="-fx-padding: 5 0;"/>

                    <Button fx:id="loginButton" text="LOGIN" prefHeight="45" maxWidth="Infinity" styleClass="primary-button" onAction="#handleLogin">
                        <VBox.margin>
                            <Insets top="10" bottom="20"/>
                        </VBox.margin>
                    </Button>

                    <Separator style="-fx-opacity: 0.2;"/>

                    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 20 0 0 0;">
                        <Label text="Don't have an account?" style="-fx-text-fill: #a0a0a0;"/>
                        <Button fx:id="signupButton" text="Sign up" styleClass="text-button" onAction="#goToSignup"/>
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>