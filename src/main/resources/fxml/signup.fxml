<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainBorderPane" styleClass="root-pane" style="-fx-background-color: #090a0c;" stylesheets="@../styles/auth-theme.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiexplorer.controller.SignupController">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: #090a0c; -fx-background-color: #090a0c; -fx-control-inner-background: #090a0c; -fx-border-width: 0;">
            <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS" style="-fx-background-color: #090a0c;">
                <padding>
                    <Insets top="40" right="20" bottom="40" left="20"/>
                </padding>

                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 30 0;">
                    <Label text="SYNONYM" styleClass="title-logo"/>
                    <Label text="Create Your Account" styleClass="subtitle-text" style="-fx-text-fill: #9c27b0;"/>
                </VBox>

                <VBox styleClass="form-container" spacing="5">

                    <VBox styleClass="form-field-box">
                        <Label text="Full Name" styleClass="form-label"/>
                        <TextField fx:id="fullNameField" promptText="Enter your full name" styleClass="text-field"/>
                    </VBox>

                    <VBox styleClass="form-field-box">
                        <Label text="Email Address" styleClass="form-label"/>
                        <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field"/>
                    </VBox>

                    <VBox styleClass="form-field-box">
                        <Label text="Username" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="3-20 characters (alphanumeric)" styleClass="text-field"/>
                    </VBox>

                    <VBox styleClass="form-field-box" spacing="4">
                        <Label text="Password" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="8+ chars, uppercase, lowercase, digit, special" styleClass="text-field"/>
                        <ProgressBar fx:id="strengthBar" prefHeight="4" maxWidth="Infinity" styleClass="progress-bar"/>
                        <Label fx:id="strengthLabel" text="" style="-fx-font-size: 11px; -fx-text-fill: #a0a0a0;"/>
                    </VBox>

                    <VBox styleClass="form-field-box">
                        <Label text="Confirm Password" styleClass="form-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" styleClass="text-field"/>
                    </VBox>

                    <Label fx:id="errorLabel" text="" styleClass="error-label"/>

                    <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="signupButton" text="CREATE ACCOUNT" prefHeight="45" maxWidth="Infinity" styleClass="primary-button" onAction="#handleSignup"/>
                        <Button fx:id="backButton" text="Back to Login" prefHeight="45" maxWidth="Infinity" styleClass="secondary-button" onAction="#goToLogin"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>